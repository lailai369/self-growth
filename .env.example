# ====== Self-Growth 插件环境变量 ======

# ---------- 核心功能开关 ----------
# 是否开启每日自动复盘功能
# 类型: boolean
# 默认: true
SELF_GROWTH_ENABLE_DAILY_REVIEW=true

# 是否允许插件自动优化已有的技能
# 类型: boolean
# 默认: false
SELF_GROWTH_AUTO_OPTIMIZE_SKILLS=false

# ---------- 路径配置 ----------
# 对话日志的存储路径
# 类型: string
# 默认: ./chat_logs
SELF_GROWTH_CHAT_LOGS_PATH=./chat_logs

# 长期记忆文件的存储路径
# 类型: string
# 默认: ./memory
SELF_GROWTH_MEMORY_PATH=./memory

# ---------- 日志与调试 ----------
# 对话日志的保留天数
# 类型: number
# 默认: 30
SELF_GROWTH_LOG_RETENTION_DAYS=30

# 是否开启调试模式
# 类型: boolean
# 默认: false
SELF_GROWTH_DEBUG=false
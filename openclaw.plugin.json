{
  "id": "self-growth",
  "name": "Self Growth Engine",
  "version": "3.0.0",
  "description": "让 Agent 具备自我成长、复盘与技能进化能力的插件。支持对话日志、偏好提取与注入、双引擎反思、技能自动生成与生命周期管理、每日复盘、技能评分与自动清理。",
  "author": "lailai",
  "license": "MIT",
  "activation": {
    "onStartup": true
  },
  "capability": {
    "hooks": ["session_start", "before_prompt_build", "agent_end","before_compaction"]
  },
  "contracts": {
    "tools": [
      "daily_analyze_tool",
      "record_session_insight"
    ],
    "hooks": [
      "session_start",
      "before_prompt_build",
      "agent_end",
      "before_compaction"
    ]
  },
  "outputHooks": [
    "session_start",
    "before_prompt_build",
    "agent_end",
    "before_compaction"
  ],
  "toolMetadata": {
    "daily_analyze_tool": {
      "optional": true
    },
    "record_session_insight": {
      "optional": true
    }
  },
  "install": {
    "ignore": [
      "memory",
      "chat_logs",
      "skills"
    ]
  },
  "skills": [
    "./skills"
  ],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enableDailyReview": {
        "type": "boolean",
        "default": true,
        "description": "是否开启每日自动复盘功能"
      },
      "logRetentionDays": {
        "type": "integer",
        "default": 30,
        "description": "对话日志的保留天数"
      },
      "memoryPath": {
        "type": "string",
        "default": "./memory",
        "description": "长期记忆文件的存储路径"
      },
      "autoOptimizeSkills": {
        "type": "boolean",
        "default": false,
        "description": "是否允许插件自动优化已有的技能"
      },
      "skillsOutputDir": {
        "type": "string",
        "default": "./skills",
        "description": "技能文件输出目录"
      }
    }
  }
}